# Public, build-time variables consumed by Vite / the client bundle.
# These are NOT secrets — the Supabase anon ("publishable") key is shipped to the
# browser by design and is protected by Row-Level Security. Copy to `.env` and fill in.
#
# Server-side SECRETS do NOT belong here — see `.dev.vars.example` (local) and the
# Cloudflare Worker secrets store (production).

SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<supabase-anon-key>"

VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<supabase-anon-key>"
VITE_SUPABASE_PROJECT_ID="<project-ref>"
